import ccxt

# 1. Настройки (СТРОГО SWAP)
swap_config = {'options': {'defaultType': 'swap'}}

# Инициализация бирж (исправлено на swap)
exchange_ids = ['bybit', 'okx', 'kucoinfutures', 'mexc', 'gate']
swap_exchanges = {}

for ex_id in exchange_ids:
    ccxt_class = getattr(ccxt, ex_id)
    # Применяем конфиг swap ко всем
    swap_exchanges[ex_id] = ccxt_class(swap_config)
    print(f"Инициализирована: {ex_id} (swap)")

# 2. Фильтры и загрузка рынков
BLOCKLIST = {'UP/USDT', 'VANRY/USDT', 'USDE/USDT', 'FDUSD/USDT'}
print("Загрузка фьючерсных рынков...")
for name, ex in swap_exchanges.items():
    try:
        ex.load_markets()
    except Exception as e:
        print(f"Ошибка {name}: {e}")

print("✅ Фьючерсы загружены!")

while True:
    try:
        swap_data = []
        for name, exchange in swap_exchanges.items():
            try:
                # Получение данных с биржи
                tickers = exchange.fetch_tickers()
                for k, v in tickers.items():
                    # Фильтрация USDT/USDC (сохранена логика оригинала)
                    if (k.endswith('/USDT:USDT') or k.endswith('/USDC:USDC')):
                        pair_name = k.split(':')[0] # Упрощенная нормализация
                        if pair_name not in BLOCKLIST and v.get('last'):
                            swap_data.append({
                                'Pair': pair_name, 'ex': name,
                                'price': float(v['last']),
                                'symbol': k
                            })
            except Exception: continue # Обработка ошибок
        break # Для примера, в оригинале - бесконечный цикл
    except Exception: break

